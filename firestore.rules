rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && request.resource.data.keys().hasAll(['uid', 'email']);
      
      match /chats/{chatId} {
        allow list, get: if isOwner(userId);
        allow create, update, delete: if isOwner(userId) && isValidId(chatId);
        
        match /messages/{messageId} {
          allow list, get: if isOwner(userId);
          allow create: if isOwner(userId) && isValidId(messageId);
        }
      }
      
      match /reports/{reportId} {
        allow list, get: if isOwner(userId);
        allow create, delete: if isOwner(userId) && isValidId(reportId);
      }
    }
  }
}
